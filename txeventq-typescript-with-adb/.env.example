# Oracle ADB (Thin mode + Cloud Wallet)
# ORACLE_CONNECT_STRING can be a wallet TNS alias (recommended), e.g. "mydb_high"
ORACLE_USER=txeventq_user
ORACLE_PASSWORD=CHANGE_ME
ORACLE_CONNECT_STRING=your_adb_tns_alias_high
ORACLE_WALLET_PATH=/absolute/path/to/unzipped/wallet
# Set only when wallet keys are encrypted:
ORACLE_WALLET_PASSWORD=

# Subscriber tuning
SUBSCRIBER_BATCH_SIZE=25
SUBSCRIBER_WAIT_SECONDS=5
SUBSCRIBER_RETRY_ATTEMPTS=3
SUBSCRIBER_RETRY_DELAY_MS=1000

# DB reconnect tuning
# 0 means reconnect forever (recommended for long-running services)
DB_RECONNECT_MAX_ATTEMPTS=0
DB_RECONNECT_INITIAL_DELAY_MS=1000
DB_RECONNECT_MAX_DELAY_MS=30000
